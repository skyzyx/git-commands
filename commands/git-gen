#!/usr/bin/env bash
set -uo pipefail

DIFF_CONTEXT=5 # Default diff context lines
PREV_COMMITS_WINDOW=5 # Default number of previous commit titles to fetch for context

DIFF="$(
  git diff --staged -U"${DIFF_CONTEXT}" -- . \
    ':(exclude)*.lock' \
    ':(exclude)*lockfile' \
    ':(exclude)*lock.json' \
    ':(exclude)*lock.yaml' \
    ':(exclude)go.sum' \
    ':(exclude)Cartfile.resolved' \
    ':(exclude)Package.resolved' \
    ;
)"
if [[ -z "${DIFF}" ]]; then
  echo "No staged changes detected. Run 'git add' first."
  exit 1
fi

MAIN_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
if [[ -z "${MAIN_BRANCH}" ]]; then
  MAIN_BRANCH="main"
  if ! git rev-parse --verify "${MAIN_BRANCH}" >/dev/null 2>&1; then
    MAIN_BRANCH="master"
  fi
fi

CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

# Fetch the last N commit titles unique to the current branch (not on main branch)
if [[ "${CURRENT_BRANCH}" != "${MAIN_BRANCH}" ]]; then
  PREV_COMMITS="$(git log "${MAIN_BRANCH}.." --pretty=format:%s -n "${PREV_COMMITS_WINDOW}" 2>/dev/null || true)"
else
  # If on main branch, fetch recent commits
  PREV_COMMITS="$(git log --pretty=format:%s -n "${PREV_COMMITS_WINDOW}" 2>/dev/null || true)"
fi

if [[ -z "${PREV_COMMITS}" ]]; then
  PREV_COMMITS="(no previous commits available)"
fi

# Wrap previous commits in a XML-like tag for structured input to the model
PREV_COMMITS_TAG="<previous_commits>\n${PREV_COMMITS}\n</previous_commits>"

# Summarization per File
ACCUMULATED_CHANGES="${PREV_COMMITS_TAG}"

# Include previous commits and accumulated file summaries as context for each file analysis
INPUT_FOR_CHUNK="<previous_changes>\n${ACCUMULATED_CHANGES}\n</previous_changes>\n<diff>\n${DIFF}\n</diff>"

FILE_CHANGES_PROMPT="$(
cat << EOF
You are an expert software engineer who writes clear and concise git commit messages.

Follow these instructions precisely.

1. Synthesize a commit message that captures the overall intent and impact of the changes. Focus on the "why" and "what" rather than the "how".

2. Use the "conventional commits" format, starting with a type (e.g., feat, fix, refactor) followed by a brief description. For example: "feat: add user authentication flow".

3. Given the git diff for a single file, summarize the changes into a single sentence. Focus on the intent and impact of the changes rather than just listing them. Prefix the response with '* ' so that it can be used as a list item in a Markdown document. Limit the output to a maximum of 120 characters. Do this for each file separately. If the diff includes added or removed functions, try to infer their purpose. Use the previous changes as context to understand how this file has evolved.

4. Use past tense and active voice in the summary. For example, say "Refactored the authentication flow to improve security" instead of "Refactor authentication flow". Always complete sentences with a period.

5. If there are multiple bulletpoints that are extremely similar, try to consolidate them into a single bulletpoint that captures the overall change. For example, if there are multiple bulletpoints about adding logging to different functions, you could consolidate them into a single bulletpoint like "* Added logging to key functions for better observability."

6. All instructions before this are to create the 'git commit' body portion of the message. The following instructions are for synthesizing the 'git commit' title, which should be a concise summary of the overall changes. Review the summaries of changes you've already created, along with the previous commit messages for context. Return **only** the commit message itself, without any additional explanation or formatting. Do not include the list of changes or previous commits in the output. Limit the final 'git commit' title message to 80 characters maximum.

7. The final format of the message should be a single line for the title, followed by two newlines, and then the body which consists of the list of changes. For example:

    ---
    feat: Added user authentication flow.

    * Implemented login and registration endpoints in the API.
    * Added JWT-based authentication and middleware for protected routes.
    * Added unit tests for the authentication logic and updated API documentation.
    ---

8. The final commit message must use past tense and active voice in the summary. For example, say "Refactored the authentication flow to improve security" instead of "Refactor authentication flow". The final commit message must end with a period, and AFTER the conventional commit type, it must begin with a capital letter.

9. Do not respond with anything other than the final commit message. Do not include any explanations, reasoning, or the list of changes in the output. The output should be exactly the commit message formatted as specified above, and nothing else.
EOF
  )"

# echo "-------------------------------------------------------------------------"
# printf "%s\n\n%s\n" "${FILE_CHANGES_PROMPT}" "${INPUT_FOR_CHUNK}"
# echo "-------------------------------------------------------------------------"

FINAL_COMMIT_MESSAGE="$(echo "${INPUT_FOR_CHUNK}" | claude \
  --system-prompt "${FILE_CHANGES_PROMPT}" \
  --print \
  --output-format text \
  --model 'claude-haiku-4-5' \
  --no-session-persistence 2>/dev/null || true)"

FINAL_COMMIT_MESSAGE="$(
  printf "%s" "${FINAL_COMMIT_MESSAGE}" \
    | sed 's/^[[:space:]]*//; s/[[:space:]]*$//' \
    | sed -E 's,\[([0-9]+;)*([0-9]+)m,,g; s,\x1B,,g; s,^>\s+,,' \
)"

TEMP_FILE="$(mktemp)";
printf "%s\n" "${FINAL_COMMIT_MESSAGE}" > "${TEMP_FILE}"

if git commit --file="${TEMP_FILE}" --edit; then
  rm "${TEMP_FILE}"
else
  echo "Commit failed. Final commit message was:"
  echo "-------------------------------------------------------------------------"
  printf "%s\n" "${FINAL_COMMIT_MESSAGE}"
  echo "-------------------------------------------------------------------------"
fi
